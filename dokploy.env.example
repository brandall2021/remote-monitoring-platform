# Dokploy Deployment Configuration
# ================================
#
# Option 1: Deploy with Docker Compose (Full Stack)
# - Upload docker-compose.dokploy.yml to Dokploy
# - Configure environment variables in Dokploy UI
#
# Option 2: Deploy Server Only (Database external)
# - Deploy server/ folder as a Docker app in Dokploy
# - Use external PostgreSQL and Redis
# - Configure DATABASE_URL and REDIS_URL in Dokploy

# Environment Variables for Dokploy
# Configure these in Dokploy UI under "Environment"

# Database (use Dokploy PostgreSQL service or external)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=remote_monitoring

# JWT Secrets (generate random strings for production)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (use Dokploy Redis service or external)
REDIS_URL=redis://redis:6379

# Server
PORT=3000
NODE_ENV=production

# CORS (your domain)
CORS_ORIGIN=https://your-domain.com

# Agent
AGENT_REGISTRATION_TOKEN=change-this-to-random-token

# Screenshots
SCREENSHOTS_DIR=./uploads/screenshots

{
  "name": "remote-monitoring-agent",
  "version": "1.0.0",
  "description": "Remote Monitoring Agent for Windows",
  "main": "dist/agent.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/agent.ts",
    "build": "tsc",
    "start": "node dist/agent.js",
    "package": "pkg dist/agent.js --targets node18-win-x64 --output agent.exe"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "node-screenshot-desktop": "^1.0.0",
    "os": "^0.1.2",
    "socket.io-client": "^4.7.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
